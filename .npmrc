strict-peer-dependencies=false
auto-install-peers=true
prefer-workspace-packages=true
link-workspace-packages=true
# Reject installs on out-of-range Node versions (see root package.json
# engines). better-sqlite3's native binding silently breaks on Node v25 —
# install/build appear to succeed but the daemon crashes on its first
# SQLite open. engine-strict makes pnpm error out up front.
engine-strict=true
