{
  "name": "@gian/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx --test-reporter spec test/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "postinstall": "node ../proxies/cc-proxy/scripts/fix-node-pty-permissions.cjs"
  },
  "dependencies": {
    "@gian/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@slack/bolt": "^4.4.0",
    "better-sqlite3": "^11.5.0",
    "discord.js": "^14.21.0",
    "hono": "^4.6.14",
    "node-pty": "^1.1.0-beta40"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.2"
  }
}
