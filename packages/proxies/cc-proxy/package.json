{
  "name": "@gian/cc-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/cli/spawn.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/src/cli/spawn.js",
    "test": "npm run build && node --test dist/test/*.test.js dist/test/unit/**/*.test.js",
    "test:smoke": "npm run build && node --test dist/test/smoke.test.js",
    "test:unit": "npm run build && node --test dist/test/service.test.js dist/test/unit/**/*.test.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "postinstall": "node scripts/fix-node-pty-permissions.cjs"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@gian/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-pty": "^1.1.0-beta40",
    "zod": "^4.3.6"
  }
}
